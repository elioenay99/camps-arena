# =====================================================================
# Arena — variáveis de ambiente (copie para .env.local e preencha)
#
# Em DEV local: preencha as PÚBLICAS com os valores do seu projeto Supabase.
# A service_role é OPCIONAL (só se for rodar scripts admin/CLI server-side;
# o app não a lê em runtime).
# Na VERCEL (deploy via Marketplace): as chaves de Supabase abaixo são
# INJETADAS automaticamente pela integração — você NÃO precisa criá-las
# à mão. A única chave que você configura por ambiente é NEXT_PUBLIC_SITE_URL.
# Detalhes em docs/deploy-vercel.md.
# =====================================================================

# --- Aplicação ---
# URL canônica do site — base para metadados/OG (metadataBase em layout.tsx).
# NÃO é injetada pela integração Supabase: configure manualmente em cada
# ambiente Vercel (Production = domínio canônico; Preview/Dev conforme).
# É inlined em build time — trocar o domínio exige novo deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase: PÚBLICAS (expostas ao browser) ---
# Auto-injetadas pela integração Supabase do Marketplace da Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: SECRETAS (somente server-side; NUNCA com prefixo NEXT_PUBLIC_) ---
# service_role: bypassa RLS — uso administrativo server-side. Auto-injetada
# pela integração na Vercel. Mantenha fora de qualquer bundle de cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string Postgres para migrations/admin via CLI (uso server-side,
# fora do runtime Next). A integração do Marketplace NÃO cria uma chave
# chamada DATABASE_URL — ela expõe POSTGRES_URL / POSTGRES_URL_NON_POOLING.
# Para migrations manuais, copie o valor de POSTGRES_URL_NON_POOLING (conexão
# direta, sem pgbouncer). DDL/migrations são SEMPRE aplicadas manualmente.
DATABASE_URL=

# --- API-Football (busca de clube + escudo; somente server-side) ---
# Chave do tier grátis (dashboard.api-football.com/register, sem cartão, 100 req/dia).
# Lida só na Server Action de busca; NUNCA com prefixo NEXT_PUBLIC_.
API_FOOTBALL_KEY=

# NOTA: NÃO comite .env.local (já no .gitignore). Só este .env.example
# (sem segredos reais) vai para o repositório.

# NOTA: as variáveis de runtime são validadas em build/boot por src/lib/env.ts
# (fail-fast): faltando NEXT_PUBLIC_SUPABASE_URL ou NEXT_PUBLIC_SUPABASE_ANON_KEY,
# o build/dev falha nomeando a variável. API_FOOTBALL_KEY é opcional (a busca de
# clube degrada graciosamente) e em branco conta como ausente.
