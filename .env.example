# =====================================================================
# Arena — variáveis de ambiente (copie para .env.local e preencha)
# =====================================================================

# --- Aplicação ---
# URL pública do site (usada em metadados, links e redirects de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (preenchido na FASE 2 — via Marketplace da Vercel) ---
# Públicas (expostas ao browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreta (somente server-side; NUNCA expor com prefixo NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=

# Connection string (migrations/admin — uso server-side):
DATABASE_URL=
